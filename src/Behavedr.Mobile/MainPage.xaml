<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Behavedr.Mobile.MainPage"
             Title="Behavedr EDR"
             BackgroundColor="{AppThemeBinding Light=#F7F8FA, Dark=#0F1419}">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="16">

            <Label Text="Behavedr"
                   FontSize="28"
                   FontAttributes="Bold"
                   TextColor="{StaticResource Primary}" />

            <Label x:Name="StatusLabel"
                   Text="Starting agent…"
                   FontSize="16" />

            <Label x:Name="PlatformLabel"
                   FontSize="14"
                   Opacity="0.8" />

            <BoxView HeightRequest="1" Color="#CCC" Margin="0,8" />

            <Label Text="Registered monitors"
                   FontAttributes="Bold"
                   FontSize="18" />

            <VerticalStackLayout x:Name="MonitorsList" Spacing="6" />

            <BoxView HeightRequest="1" Color="#CCC" Margin="0,8" />

            <Label Text="Phone agents share GIDR President + Council of Elders scoring with desktop (Windows, Linux, macOS)."
                   FontSize="12"
                   Opacity="0.7" />

            <Button Text="Refresh signals"
                    Clicked="OnRefreshClicked"
                    BackgroundColor="{StaticResource Primary}"
                    TextColor="White"
                    CornerRadius="8" />

            <Label x:Name="SignalsLabel"
                   FontSize="12"
                   FontFamily="Courier New"
                   LineBreakMode="WordWrap" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
