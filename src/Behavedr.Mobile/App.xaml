<?xml version="1.0" encoding="UTF-8" ?>
<Application xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Behavedr.Mobile.App">
    <Application.Resources>
        <ResourceDictionary>
            <Color x:Key="Primary">#1B2A4A</Color>
            <Color x:Key="Accent">#3DDC84</Color>
            <Color x:Key="Danger">#E53935</Color>
            <Style TargetType="Label">
                <Setter Property="TextColor" Value="{AppThemeBinding Light=#1B2A4A, Dark=#F5F5F5}" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
