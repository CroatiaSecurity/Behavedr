<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <Version>0.0.1</Version>
    <AssemblyVersion>0.0.1.0</AssemblyVersion>
    <FileVersion>0.0.1.0</FileVersion>
    <InformationalVersion>0.0.1</InformationalVersion>
    <Product>Behavedr</Product>
    <Company>CroatiaSecurity</Company>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\Behavedr.Core\Behavedr.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Include="..\..\Assets\**\*" Link="Assets\%(RecursiveDir)%(Filename)%(Extension)" CopyToOutputDirectory="PreserveNewest" Condition="Exists('..\..\Assets')" />
  </ItemGroup>

</Project>
