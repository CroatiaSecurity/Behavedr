{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Behavedr": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Behavedr": "Debug"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/behavedr-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  },
  "Scoring": {
    "UserTargetedMultiplier": 2.0,
    "PresidentKillThreshold": 95.0,
    "HighScoreAlertThreshold": 50.0
  },
  "Agent": {
    "MonitoringIntervalSeconds": 5,
    "EnableSelfProtection": true
  },
  "Response": {
    "Mode": "AlertOnly",
    "AlertThreshold": 50.0,
    "ResponseThreshold": 75.0,
    "EnableQuarantine": true,
    "EnableProcessKill": true,
    "QuarantinePath": "quarantine"
  },
  "Communication": {
    "ServerUrl": "https://localhost:5443",
    "AgentId": "",
    "ClientCertPath": "",
    "ClientCertPassword": "",
    "CaCertPath": "",
    "TimeoutSeconds": 30,
    "HeartbeatIntervalSeconds": 60,
    "Enabled": false
  },
  "Update": {
    "Enabled": true,
    "CheckIntervalHours": 6
  }
}
