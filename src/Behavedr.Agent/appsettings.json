{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information",
      "Behavedr": "Debug"
    }
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning",
        "Behavedr": "Debug"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/behavedr-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 14,
          "fileSizeLimitBytes": 10485760,
          "rollOnFileSizeLimit": true
        }
      }
    ]
  },
  "Scoring": {
    "UserTargetedMultiplier": 2.0,
    "PresidentKillThreshold": 95.0,
    "HighScoreAlertThreshold": 50.0
  },
  "Agent": {
    "MonitoringIntervalSeconds": 5,
    "EnableSelfProtection": true,
    "EnableIntegrityCheck": true
  }
}
